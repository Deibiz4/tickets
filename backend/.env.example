# Configuración de la base de datos
DATABASE_URL=postgresql://user:password@db:5432/ticketsdb

# Configuración de JWT
JWT_SECRET=tu_secreto_super_seguro_aqui
JWT_EXPIRES_IN=24h

# Configuración del servidor
NODE_ENV=development
PORT=3000

# Configuración de CORS (Frontend URL)
CORS_ORIGIN=http://localhost:5173

# Configuración de Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=usuario@example.com
SMTP_PASS=tu_contraseña_email
SMTP_FROM=alertas@example.com

# Microsoft OAuth (Opcional - Si se usa Login con Microsoft)
MICROSOFT_CLIENT_ID=tu_client_id_azure
MICROSOFT_CLIENT_SECRET=tu_client_secret_azure
MICROSOFT_CALLBACK_URL=http://localhost:3000/api/auth/microsoft/callback
